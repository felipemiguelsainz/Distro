# ---------------------------------------------------------------------------
# Distro environment variables
# ---------------------------------------------------------------------------

# Supabase MAESTRA (control plane). Guarda la tabla `tenants`.
# Esta es la única Supabase que se conoce en build/deploy time.
NEXT_PUBLIC_MASTER_SUPABASE_URL=https://your-master-project.supabase.co
NEXT_PUBLIC_MASTER_SUPABASE_ANON_KEY=your-master-anon-key

# Service role de la maestra: SOLO server-side. Permite leer credenciales de
# tenants y resolver el tenant del usuario sin exponer la tabla al browser.
MASTER_SUPABASE_SERVICE_ROLE_KEY=your-master-service-role-key

# Anthropic API (chat IA + Centro de Recomendaciones)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Alertas automáticas (Resend) — usadas por la Edge Function alertas-diarias.
# Se configuran como secrets del proyecto MAESTRO (supabase secrets set ...).
RESEND_API_KEY=re_...
ALERTAS_FROM_EMAIL=alertas@distro.app
ALERTAS_FROM_NAME=Distro
